# =============================================================================
# CP Plus Agentic Suite — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual API keys:
#   cp .env.example .env

# --- LLM Keys ---
# Mistral Scale-as-you-go (primary — no rate limits, pay-per-token)
MISTRAL_API_KEY="your-mistral-api-key-here"
# Optional: Backup Mistral key for failover resilience (separate account)
MISTRAL_BACKUP_API_KEY=""
# Model selection — mistral-large-latest is recommended for scale-as-you-go
MISTRAL_MODEL="mistral-large-latest"
# Gemini kept as final fallback (Tier 3)
GEMINI_API_KEY="your-gemini-api-key-here"

# --- Model Routing (use right model for each task complexity) ---
MISTRAL_MODEL_HEAVY="mistral-large-latest"
MISTRAL_MODEL_LIGHT="mistral-small-latest"

# --- Mistral OCR (better table/layout extraction than pypdf) ---
USE_MISTRAL_OCR=true

# --- Training Data Collection (set true to capture prompt-completion pairs) ---
COLLECT_TRAINING_DATA=false

# --- CORS (comma-separated allowed origins) ---
ALLOWED_ORIGINS="https://*.ngrok-free.app,https://*.watson-orchestrate.ibm.com"

# --- Flask ---
FLASK_SECRET_KEY="generate-a-random-hex-string-here"
FLASK_DEBUG=false

# --- Admin Endpoints ---
ADMIN_API_KEY="generate-a-random-key-for-admin-access"
